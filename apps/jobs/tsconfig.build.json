{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "replacers": {
      "default": {
        "enabled": true,
        "fileExtensions": {
          ".js": ".js"
        }
      }
    }
  }
}
