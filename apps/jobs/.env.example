NODE_ENV=development
PORT=4000

# Use the local Supabase DB URL from `supabase status`, or a hosted Supabase
# Postgres connection string in production.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase project used for auth and service-role operations.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Admin console origin during local development.
ADMIN_ORIGIN=http://localhost:5173

# Shared secret accepted by POST /openapi/analysis. This must match
# youchannel/.env OPENAPI_SHARED_KEY.
OPENAPI_SHARED_KEY=

# Gemini analysis worker.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

LOG_LEVEL=info

# Optional Sentry reporting.
SENTRY_DSN=
SENTRY_ENV=local

# pg-boss retry tuning.
ANALYSIS_JOB_RETRY_LIMIT=3
ANALYSIS_JOB_EXPIRE_SECONDS=900
ANALYSIS_JOB_RETRY_DELAY_SECONDS=300
